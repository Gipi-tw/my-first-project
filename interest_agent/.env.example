# ── Anthropic API ────────────────────────────────────────────
# 在 https://console.anthropic.com 取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email 設定（以 Gmail 為例）───────────────────────────────
# 寄件人 Gmail 帳號
EMAIL_SENDER=your_email@gmail.com

# Gmail App Password（非登入密碼！）
# 設定步驟：Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼 → 建立
EMAIL_PASSWORD=your_gmail_app_password

# 收件人（可填相同 Gmail）
EMAIL_RECIPIENT=recipient@gmail.com

# ── SMTP（使用 Gmail 可保持預設值）──────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ── Profile Builder 設定 ─────────────────────────────────────
# 個人部落格網址（用於抓取文章分析興趣）
PERSONAL_BLOG_URL=https://gipi.tw

# Google Drive OAuth2 憑證檔案路徑（放在 interest_agent/ 目錄下）
# 取得步驟：Google Cloud Console → API & Services → Credentials → 建立 OAuth2 Desktop App 憑證
GOOGLE_CREDENTIALS_FILE=credentials.json

# token.json 路徑（首次 OAuth 授權後自動產生，無需手動設定）
GOOGLE_TOKEN_FILE=token.json

# 要掃描的 Google Drive 資料夾 ID（從資料夾分享連結取得）
# 例如 https://drive.google.com/drive/folders/XXXXXX → ID 為 XXXXXX
GOOGLE_DRIVE_FOLDER_ID=1wlYnXZrXipOQc5AcQGWtZnSMNXavEfC-
